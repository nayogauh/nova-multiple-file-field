{
    "name": "nayogauh/nova-multiple-file-field",
    "description": "A Laravel Nova field to upload, preview and manage multiple files. Compatible with Nova 4 & 5 and Laravel 9 to 13.",
    "keywords": [
        "laravel",
        "nova",
        "field",
        "file",
        "files",
        "upload",
        "multiple"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "laravel/nova": "^4.0 || ^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0 || ^8.0 || ^9.0 || ^10.0",
        "phpunit/phpunit": "^9.0 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nayogauh\\MultipleFile\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nayogauh\\MultipleFile\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nayogauh\\MultipleFile\\FieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
